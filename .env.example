# HubSpot Private App access token
HUBSPOT_ACCESS_TOKEN=

# Express server port (default: 3000)
PORT=3000

# ── SFTP file fetcher (required) ─────────────────────────────────────────────
# POST /sync connects to this server, downloads the CIF and DDA CSV files,
# runs the sync, then deletes the local copies.
#
# SFTP_HOST        — SFTP server hostname (e.g. sftp.bank.com)
# SFTP_PORT        — SFTP port (default: 22)
# SFTP_USER        — SFTP username
# SFTP_PASSWORD    — SFTP password (used when SFTP_PRIVATE_KEY is not set)
# SFTP_PRIVATE_KEY — absolute path to private key file (optional, preferred)
# SFTP_REMOTE_DIR  — remote directory containing the CSV files
# DATA_DIR         — temporary local folder for downloaded CSVs (deleted after sync)

SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY=
SFTP_REMOTE_DIR=/uploads
DATA_DIR=./data

# ── File logging ──────────────────────────────────────────────────────────────
# LOG_DIR    — root folder for log files (default: ./logs)
#              daily sub-folders created automatically: logs/YYYY/MM/DD/
# LOG_FORMAT — 'text' (syslog-style, default) or 'json' (one JSON object per line)
# LOG_LEVEL  — minimum level to write: 'info' (default) | 'warn' | 'error'

LOG_DIR=./logs
LOG_FORMAT=text
LOG_LEVEL=info

# HubSpot Deal pipeline and stage internal IDs
# Find them in HubSpot: Settings → Deals → Pipelines → "..." menu → Copy ID
# Default values work for a standard out-of-the-box HubSpot portal
DEAL_PIPELINE_ID=default
DEAL_STAGE_ID=appointmentscheduled
